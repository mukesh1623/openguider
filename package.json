{
  "name": "openguider",
  "version": "0.1.0",
  "description": "OpenGuider AI Companion",
  "author": "Metehan Kızılcık",
  "license": "GPL-3.0-or-later",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect",
    "test": "node --test \"tests/**/*.test.js\"",
    "pack": "electron-builder --dir",
    "dist": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "dist:win": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis",
    "dist:mac": "electron-builder --mac dmg zip",
    "dist:linux": "electron-builder --linux AppImage deb"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.26",
    "@langchain/core": "^1.1.39",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/openai": "^1.4.4",
    "electron-store": "^8.2.0",
    "google-tts-api": "^2.0.2",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^34.3.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^27.0.1",
    "rcedit": "^5.0.2"
  },
  "build": {
    "appId": "com.openguider.desktop",
    "productName": "OpenGuider",
    "icon": "renderer/assets/logo.png",
    "afterPack": "./scripts/after-pack.js",
    "asar": true,
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "src/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "npmRebuild": true,
    "mac": {
      "icon": "renderer/assets/logo.png",
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "sign": false
    },
    "win": {
      "icon": "renderer/assets/logo.png",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "linux": {
      "icon": "renderer/assets/logo.png",
      "category": "Utility",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  }
}
